{% extends 'emails/_base.html.twig' %}

{% block heading %}Votre bon cadeau{% endblock %}

{% block content %}
<p style="margin:0 0 16px; font-size:15px; line-height:1.6; color:#374151;">Bonjour {{ cadeau.offreur }},</p>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:20px 0;">
<tr><td style="background-color:#e0f2fe; border-left:4px solid #0ea5e9; border-radius:8px; padding:16px 20px; font-size:14px; line-height:1.5; color:#0c4a6e;">
  Merci pour votre achat ! Vous trouverez en pi&egrave;ce jointe votre bon cadeau au nom de <strong>{{ cadeau.beneficiaire }}</strong>.
</td></tr>
</table>

<p style="margin:16px 0 0; font-size:15px; line-height:1.6; color:#374151;">Bonne journ&eacute;e !</p>
{% endblock %}
