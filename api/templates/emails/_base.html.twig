<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% block title %}{% endblock %}</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f5f7; font-family:Arial, Helvetica, sans-serif; color:#1a1a2e; -webkit-text-size-adjust:100%;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f5f7;">
<tr><td align="center" style="padding:24px 16px;">

<table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px; width:100%; background-color:#ffffff; border-radius:12px; overflow:hidden; border:1px solid #e5e7eb;">
  {% block header %}
  <tr>
    <td style="padding:28px 32px 20px; border-bottom:1px solid #eef0f2;">
      <h1 style="margin:0 0 4px; font-size:20px; font-weight:700; color:#1a1a2e;">{% block heading %}{% endblock %}</h1>
      <p style="margin:0; font-size:14px; color:#6b7280;">{% block subtitle %}{{ client.name }}{% endblock %}</p>
    </td>
  </tr>
  {% endblock %}

  <tr>
    <td style="padding:28px 32px;">
      {% block content %}{% endblock %}
    </td>
  </tr>

  <tr>
    <td style="padding:20px 32px; background-color:#f9fafb; border-top:1px solid #eef0f2;">
      <p style="margin:0; font-size:13px; line-height:1.6; color:#6b7280;">
        <strong style="color:#374151;">{{ client.name }}</strong><br>
        {% if client.phone is defined and client.phone %}TEL : {{ client.phone }}<br>{% endif %}
        {% if client.email is defined and client.email %}<a href="mailto:{{ client.email }}" style="color:#3b82f6; text-decoration:none;">Nous &eacute;crire</a>{% endif %}
        {% if client.website is defined and client.website %} &middot; <a href="{{ client.website }}" style="color:#3b82f6; text-decoration:none;">{{ client.website|replace({'https://': '', 'http://': ''}) }}</a>{% endif %}
      </p>
    </td>
  </tr>
</table>

</td></tr>
</table>
</body>
</html>
