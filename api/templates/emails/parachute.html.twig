{% extends 'emails/_base.html.twig' %}

{% block heading %}Alerte parachute &middot; {{ immatriculation }}{% endblock %}

{% block content %}
<p style="margin:0 0 16px; font-size:15px; line-height:1.6; color:#374151;">Bonjour,</p>

{% if depassee %}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:20px 0;">
<tr><td style="background-color:#fee2e2; border-left:4px solid #ef4444; border-radius:8px; padding:16px 20px; font-size:14px; line-height:1.5; color:#991b1b;">
  <strong>&#9888; &Eacute;ch&eacute;ance d&eacute;pass&eacute;e</strong><br>
  Le reconditionnement du parachute de r&eacute;cup&eacute;ration de <strong>{{ immatriculation }}</strong> est en retard de <strong>{{ joursRestants }} jour(s)</strong>.
</td></tr>
</table>
{% else %}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:20px 0;">
<tr><td style="background-color:#fef3c7; border-left:4px solid #f59e0b; border-radius:8px; padding:16px 20px; font-size:14px; line-height:1.5; color:#92400e;">
  <strong>Reconditionnement &agrave; pr&eacute;voir</strong><br>
  Le parachute de r&eacute;cup&eacute;ration de <strong>{{ immatriculation }}</strong> doit &ecirc;tre reconditionn&eacute; dans <strong>{{ joursRestants }} jour(s)</strong>.
</td></tr>
</table>
{% endif %}

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:16px 0;">
  <tr>
    <td style="padding:10px 0; font-size:14px; color:#6b7280; border-bottom:1px solid #f3f4f6; width:45%;">A&eacute;ronef</td>
    <td style="padding:10px 0; font-size:14px; font-weight:600; color:#1a1a2e; border-bottom:1px solid #f3f4f6;">{{ immatriculation }}</td>
  </tr>
  <tr>
    <td style="padding:10px 0; font-size:14px; color:#6b7280; border-bottom:1px solid #f3f4f6; width:45%;">Dernier reconditionnement</td>
    <td style="padding:10px 0; font-size:14px; font-weight:600; color:#1a1a2e; border-bottom:1px solid #f3f4f6;">{{ dateReconditionnement }}</td>
  </tr>
  <tr>
    <td style="padding:10px 0; font-size:14px; color:#6b7280; border-bottom:1px solid #f3f4f6; width:45%;">&Eacute;ch&eacute;ance</td>
    <td style="padding:10px 0; font-size:14px; font-weight:600; color:#1a1a2e; border-bottom:1px solid #f3f4f6;">{{ echeance }}</td>
  </tr>
  <tr>
    <td style="padding:10px 0; font-size:14px; color:#6b7280; width:45%;">Jours restants</td>
    <td style="padding:10px 0; font-size:14px; font-weight:600; color:#1a1a2e;">
      {% if depassee %}
        <span style="display:inline-block; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; background-color:#fee2e2; color:#991b1b;">-{{ joursRestants }}j</span>
      {% else %}
        <span style="display:inline-block; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:600; background-color:#fef3c7; color:#92400e;">{{ joursRestants }}j</span>
      {% endif %}
    </td>
  </tr>
</table>

<p style="margin:16px 0 0; font-size:15px; line-height:1.6; color:#374151;">Merci de planifier le reconditionnement ou le remplacement du parachute dans les meilleurs d&eacute;lais.</p>
{% endblock %}
